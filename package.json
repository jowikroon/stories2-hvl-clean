{
  "name": "hans-crafted-stories",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "dev:saas": "npm run dev --workspace=@hans/saas",
    "dev:personal": "npm run dev --workspace=@hans/personal",
    "dev:thought-canvas": "npm run dev --workspace=@hans/thought-canvas",
    "build:saas": "npm run build --workspace=@hans/saas",
    "build:personal": "npm run build --workspace=@hans/personal",
    "build:thought-canvas": "npm run build --workspace=@hans/thought-canvas",
    "preview:saas": "npm run preview --workspace=@hans/saas",
    "preview:personal": "npm run preview --workspace=@hans/personal",
    "preview:thought-canvas": "npm run preview --workspace=@hans/thought-canvas",
    "lint:saas": "npm run lint --workspace=@hans/saas",
    "lint:personal": "npm run lint --workspace=@hans/personal",
    "lint:thought-canvas": "npm run lint --workspace=@hans/thought-canvas",
    "test:saas": "npm run test --workspace=@hans/saas",
    "test:personal": "npm run test --workspace=@hans/personal",
    "test:thought-canvas": "npm run test --workspace=@hans/thought-canvas",
    "dev": "echo \"Use dev:personal, dev:saas, or dev:thought-canvas\"",
    "build": "npm run build --workspace=@hans/personal && npm run build --workspace=@hans/saas && npm run build --workspace=@hans/thought-canvas",
    "lint": "npm run lint --workspace=@hans/personal && npm run lint --workspace=@hans/saas && npm run lint --workspace=@hans/thought-canvas",
    "test": "npm run test --workspace=@hans/personal && npm run test --workspace=@hans/saas && npm run test --workspace=@hans/thought-canvas",
    "typecheck": "npm run typecheck --workspace=@hans/personal && npm run typecheck --workspace=@hans/saas && npm run typecheck --workspace=@hans/thought-canvas",
    "create-saas-user": "dotenv -e apps/saas/.env -- node scripts/create-saas-user.cjs"
  },
  "overrides": {
    "esbuild": "^0.25.0"
  }
}
