# Copy this file to: all-credentials.export.env
# Then replace the placeholder values below with your real ones.
# Do NOT commit all-credentials.export.env (add it to .gitignore).

# ---- n8n (required for the "add credentials" script) ----
# Your n8n dashboard URL (the one you open in the browser)
N8N_BASE_URL=https://hansvanleeuwen.app.n8n.cloud
# API key from n8n: open n8n → Settings (gear) → n8n API → Create an API key
N8N_API_KEY=paste-your-n8n-api-key-here

# ---- Supabase (for n8n Supabase nodes) ----
# From Supabase dashboard: Project Settings → API
SUPABASE_URL=https://oejeojzaakfhculcoqdh.supabase.co
SUPABASE_SERVICE_ROLE_KEY=paste-your-service-role-key-here

# ---- AI / APIs (for n8n workflows that use Claude, OpenAI, etc.) ----
ANTHROPIC_API_KEY=paste-your-anthropic-key-here
OPENAI_API_KEY=paste-your-openai-key-here

# ---- Google Gemini (optional — direct Gemini API for edge functions / future Google control) ----
# From https://aistudio.google.com/ or Vertex AI. Enables Gemini function-calling and Google Workspace automation.
# GEMINI_API_KEY=paste-your-gemini-api-key-here

# ---- Google OAuth (for google-agent: Connect Google, Gmail/Sheets/Drive) ----
# From Google Cloud Console → APIs & Services → Credentials. Same or separate client as n8n.
# Add redirect URI: https://<project-ref>.supabase.co/functions/v1/google-oauth-callback
GOOGLE_OAUTH_CLIENT_ID=paste-your-google-oauth-client-id-here
GOOGLE_OAUTH_CLIENT_SECRET=paste-your-google-oauth-client-secret-here
# Optional: sign OAuth state (generate: openssl rand -hex 32). If unset, a default is used.
# GOOGLE_OAUTH_STATE_SECRET=paste-your-state-secret-here
# App origin for OAuth redirects (e.g. https://your-app.com or http://localhost:5173)
APP_ORIGIN=https://your-app.com

# ---- Monday.com (optional) ----
MONDAY_API_TOKEN=paste-your-monday-token-here

# ---- n8n server (set in n8n's own .env / docker-compose) ----
# Encrypts credentials at rest. Generate once: openssl rand -hex 32
# N8N_ENCRYPTION_KEY=paste-your-encryption-key-here

# ---- Commander / webhook auth ----
# Shared secret for trigger-webhook and Commander CLI (generate: openssl rand -hex 32)
COMMANDER_WEBHOOK_TOKEN=paste-your-commander-token-here

# ---- Vault adapter (optional — only if using the stub vault) ----
# VAULT_MASTER_KEY=paste-your-vault-master-key-here
# VAULT_FILE=./data/secrets.vault
# VAULT_BASE_URL=http://localhost:4000

# ---- Firecrawl (optional) ----
# FIRECRAWL_API_KEY=paste-your-firecrawl-key-here

# ---- Cloudflare (optional — for Workers deploy / DNS) ----
# CLOUDFLARE_API_TOKEN=paste-your-cloudflare-token-here
# CLOUDFLARE_ZONE_ID=paste-your-zone-id-here
# CLOUDFLARE_ACCOUNT_ID=paste-your-account-id-here
