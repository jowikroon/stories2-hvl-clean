VITE_SUPABASE_PROJECT_ID="your-supabase-project-id"
VITE_SUPABASE_PUBLISHABLE_KEY="your-supabase-anon-key"
VITE_SUPABASE_URL="https://your-project.supabase.co"

# Google login — required configuration:
#
# 1. Supabase Dashboard → Authentication → URL Configuration → Redirect URLs
#    Add BOTH of these (exact paths, no trailing slash):
#      Production:  https://<your-domain>/auth/callback
#      Local dev:   http://localhost:5173/auth/callback
#
# 2. Supabase Dashboard → Authentication → Providers → Google
#    Enable Google and paste your Client ID and Client Secret from Google Cloud Console.
#
# 3. Google Cloud Console → APIs & Services → Credentials → your OAuth 2.0 Client
#    Authorized redirect URIs: https://<your-supabase-project-ref>.supabase.co/auth/v1/callback
#    (Supabase shows the exact URI in the Google provider settings page)
#
# The app always redirects to /auth/callback after OAuth; that route is registered
# in AnimatedRoutes.tsx and navigates the user back to where they came from.

# Admin access by email — comma-separated list of emails that are always treated as admin
# regardless of the user_roles table. Works for Gmail and email/password login.
# Set this in .env.development or .env.local for local dev, and in your Cloudflare Pages
# environment variables for production.
# Example: VITE_ADMIN_EMAILS="you@gmail.com, colleague@example.com"
# Grant admin to hansvl3@gmail.com (and others as needed):
VITE_ADMIN_EMAILS="hansvl3@gmail.com"

# Cloudflare
CLOUDFLARE_API_TOKEN="your-cloudflare-api-token"
CLOUDFLARE_GLOBAL_API_KEY="your-cloudflare-global-api-key"
CLOUDFLARE_EMAIL="your-cloudflare-email"
CLOUDFLARE_ZONE_ID="your-zone-id"
CLOUDFLARE_ACCOUNT_ID="your-account-id"
CLOUDFLARE_ORIGIN_CA_KEY="your-origin-ca-key"

# Deployment: Cloudflare Pages
# Connect your GitHub repo in Cloudflare Pages dashboard
# Build command: npm run build
# Output directory: dist

# Supabase Edge Functions — set in Dashboard: Project Settings → Edge Functions → Secrets
# (Not in .env; these are server-side secrets for deployed functions.)
# LOVABLE_API_KEY=...   — required by n8n-agent (primary LLM gateway)
# OPENAI_API_KEY=...    — required by llm-resume (fallback when primary fails)

# Monday.com (Status page: clickable board link; default is hansvl3s-team-company board)
# VITE_MONDAY_BOARD_URL="https://hansvl3s-team-company.monday.com/boards/5092430975"
