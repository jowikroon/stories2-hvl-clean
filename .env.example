VITE_OLLAMA_TUNNEL_CMD="ssh -N -L 11434:localhost:11434 root@srv1402218.hstgr.cloud"

# Remote Qdrant (via SSH tunnel from primary VPS)
VITE_QDRANT_PROD_URL="http://localhost:6333" # Tunnel local port 6333 → remote 6333
VITE_QDRANT_TUNNEL_CMD="ssh -N -L 6333:localhost:6333 root@srv1402218.hstgr.cloud"

# Remote AnythingLLM (via SSH tunnel from primary VPS)
VITE_ANYTHINGLLM_PROD_URL="http://localhost:3001" # Tunnel local port 3001 → remote 3001
VITE_ANYTHINGLLM_TUNNEL_CMD="ssh -N -L 3001:localhost:3001 root@srv1402218.hstgr.cloud"

# ─────────────────────────────────────────────────────────
# SSH & TUNNELING CONFIGURATION
# ─────────────────────────────────────────────────────────

# Cloudflare Zero Trust (for secure SSH access)
VITE_CF_TUNNEL_ENABLED="true"
VITE_CF_SSH_SHORTHAND="industrial" # Access secondary as: ssh industrial
VITE_CF_ACCOUNT_ID="your-cloudflare-account-id"
VITE_CF_TUNNEL_UUID="your-cloudflare-tunnel-uuid"
VITE_CF_TUNNEL_TOKEN="your-cloudflare-tunnel-token"

# SSH Key Management
VITE_SSH_KEY_ALGORITHM="ed25519"
VITE_SSH_KEY_PATH="${HOME}/.ssh/id_ed25519_hansai"
VITE_SSH_KEY_PASSPHRASE="" # Or use SSH agent to avoid storing passphrase

# SSH Connection Pooling & Reuse
VITE_SSH_CONTROL_PATH="${HOME}/.ssh/control-%h-%p-%r"
VITE_SSH_CONTROL_MASTER="auto"
VITE_SSH_CONTROL_PERSIST="3600" # Keep connections alive for 1 hour

