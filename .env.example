VITE_EMPIRE_SCRIPTS_DIR="/opt/hansai/scripts"
VITE_EMPIRE_BACKUPS_DIR="/opt/hansai/backups"
VITE_EMPIRE_MCP_SERVERS_DIR="/opt/hansai/mcp-servers"

